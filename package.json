{
  "name": "juliannefurnishings",
  "version": "0.0.1",
  "description": "A simple furniture shop",
  "author": "Julianne Adams <julianne@julianneadams.info>",
  "license": "MIT",
  "main": "dist/server.js",
  "private": true,
  "engines": {
    "node": ">=16.0.0"
  },
  "prisma": {
    "schema": "src/components/database/schema.prisma"
  },
  "scripts": {
    "build": "tsc && tsc-alias",
    "start": "NODE_ENV=production node dist/server.js",
    "dev": "NODE_ENV=development ts-node-dev -r tsconfig-paths/register ./src/server.ts",
    "prod": "NODE_ENV=production ts-node -r tsconfig-paths/register ./src/server.ts",
    "test": "NODE_ENV=test jest --coverage --verbose",
    "test:ci": "NODE_ENV=testci jest --config ./jest.config.js --collectCoverage --coverageDirectory=\"./coverage\" --ci --reporters=default --reporters=jest-junit --watchAll=false --verbose --silent=false",
    "migrate:deploy": "prisma migrate deploy",
    "migrate:dev": "prisma migrate dev"
  },
  "devDependencies": {
    "@types/express": "^4.17.14",
    "@types/jest": "^29.2.3",
    "@types/node": "^18.11.9",
    "@types/supertest": "^2.0.12",
    "@typescript-eslint/eslint-plugin": "^5.44.0",
    "@typescript-eslint/parser": "^5.44.0",
    "eslint": "^8.28.0",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-prettier": "^8.5.0",
    "eslint-import-resolver-typescript": "^3.5.2",
    "eslint-plugin-import": "^2.26.0",
    "eslint-plugin-prettier": "^4.2.1",
    "jest": "^29.3.1",
    "jest-junit": "^15.0.0",
    "mariadb": "^3.0.2",
    "nodemon": "^2.0.20",
    "pino-pretty": "^9.1.1",
    "prettier": "^2.8.0",
    "supertest": "^6.3.1",
    "ts-jest": "^29.0.3",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "tsc-alias": "^1.7.1",
    "tsconfig-paths": "^4.1.0",
    "typescript": "^4.9.3"
  },
  "dependencies": {
    "@prisma/client": "^4.10.1",
    "body-parser": "^1.20.1",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "express-validator": "^6.14.2",
    "mysql2": "^2.3.3",
    "pino": "^8.9.0",
    "pino-http": "^8.3.3",
    "prisma": "^4.10.1",
    "sequelize": "^6.25.8"
  }
}
